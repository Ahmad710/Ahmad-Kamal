{{  'custom-banner.css' | asset_url | stylesheet_tag }}

<div class="custom-banner" id="custom-banner-{{ section.id }}">
    {% comment %} Mobile Content box {% endcomment %}
     <div class="custom-banner__header-mobile">
        {% if section.settings.heading != blank %}
            <h2 class="custom-banner__heading"> {{ section.settings.heading | escape }} </h2>
        {% endif %}
        
        {% if section.settings.description != blank %}
        <div class="custom-banner__description">
            <p> {{ section.settings.description | newline_to_br }} </p>
        </div>
        {% endif %}
     </div>

    {% comment %} banner {% endcomment %}
    <div class="custom-banner__media-container">
        {%  if section.settings.banner_image != blank %}
            {% assign image_alt = section.settings.banner_image.alt | default: section.settings.heading | escape %}
            {{ section.settings.banner_image | image_url: width: 2000 | image_tag:
                class: 'custom-banner__image',
                widths: '385, 550 750, 1100, 1500, 2000',
                sizes: '100vw',
                alt: image_alt
            }}
        {% else %}
            <div class="custom-banner__placeholder-wrapper">
                {{ 'hero-apparel-1' | placeholder_svg_tag: 'custom-banner__placeholder' }}
            </div>
        {% endif %}
    
        {% comment %} content box {% endcomment %}
        <div class="custom-banner__content-box">
            {% if section.settings.heading != blank %}
                <h2 class="custom-banner__heading custom-banner__heading--desktop"> {{ section.settings.heading | escape }} </h2>
            {% endif %}

            {% if section.settings.description != blank %}
            <div class="custom-banner__description custom-banner__description--desktop">
                <p> {{ section.settings.description | newline_to_br }} </p>
            </div>
            {% endif %}

            {% if section.settings.button_label != blank %}
            <a href="{{ section.settings.button_link | default: "#" }}" class="custom-banner__button">
                <span>{{ section.settings.button_label | escape }}</span>
                {{ 'custom-white-arrow.svg' | inline_asset_content }}
            </a>
            {% endif %}
        </div>
    </div>

    {% comment %} bottom text {% endcomment %}
    {% if section.settings.bottom_text != blank %} 
        <div class="custom-banner__ticker">
            <p class="custom-banner__ticker-text">{{ section.settings.bottom_text | escape }}</p>
        </div>
    {% endif %}

</div>


{% schema %}
{
    "name": "Custom banner",
    "settings": [
        {
            "type": "image_picker",
            "id": "banner_image",
            "label": "Banner"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "The Gift Guide"
        },
        {
            "type": "textarea",
            "id": "description",
            "label": "Description",
            "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
        },
        {
            "type": "text",
            "id": "button_label",
            "label": "Button label",
            "default": "Shop Now"
        },
        {
            "type": "url",
            "id": "button_link",
            "label": "Button link"
        },
        {
            "type": "text",
            "id": "bottom_text",
            "label": "Text below banner",
            "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
        }
    ],
    "presets": [
        {
            "name": "Custom banner"
        }
    ]
}
{% endschema %}