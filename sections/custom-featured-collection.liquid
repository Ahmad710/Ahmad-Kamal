{{  'custom-featured-collection.css' | asset_url | stylesheet_tag }}


{% schema %}
{
    "name": "Custom collection",
    "settings": [
        {
            "type": "product_list",
            "id": "product_list",
            "label": "Products"
        },
        {
            "type": "range",
            "id": "columns_desktop",
            "min": 2,
            "max": 6,
            "step": 1,
            "label": "Columns (desktop)",
            "default": 3
        }
    ],
    "presets": [
        {
            "name": "Custom collection"
        }
    ]
}
{% endschema %}
