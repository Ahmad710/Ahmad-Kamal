{{  'custom-featured-collection.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} {
    --columns-desktop: {{ section.settings.columns_desktop }};
  }
{% endstyle %}

<div class="custom-featured-collection" id="custom-featured-collection-{{ section.id }}">
    <div class="custom-featured-collection__container">
        <div class="custom-featured-collection__grid">
            {% assign limit = section.settings.products_to_show %}
            {% if section.settings.product_list != blank %}
                {% for product in section.settings.product_list limit: limit %}
                    {%- capture hotspot_pos -%} {% cycle 'pos-1', 'pos-2', 'pos-3', 'pos-4', 'pos-5', 'pos-6', %} {%- endcapture -%}

                    <div class="custom-featured-collection__card" data-prodyc-id="{{ product.id }}" data-product-handle="{{ product.handle }}">
                        <div class="custom-featured-collection__media">
                            {% if product.featured_media != blank %}
                                {{ product.featured_media | image_url: width: 1000 | image_tag: 
                                    class: 'custom-featured-collection__image',
                                    loading: 'lazy',
                                    widths: '300, 550, 750, 1000',
                                    alt: product.featured_media.alt | escape
                                }}
                            {% else %}
                                {{ 'product-1' | placeholder_svg_tag: 'custom-featured-collection__placeholder' }}
                            {% endif %}

                            {% comment %} plus button {% endcomment %}
                             <button class="custom-featured-collection__hotspot custom-featured-collection__hotspot--{{ hotspot_pos }}"
                                aria-label="Quick buy {{ product.title | escape }}"
                                aria-expanded="false" data-target="Modal-{{ product.id }}">
                                    {{ 'custom-plus-icon.svg' | inline_asset_content }}
                             </button>
                        </div>


                        {% comment %} Popup {% endcomment %}
                        <div class="custom-featured-collection__modal" id="Modal-{{ product.id }}" aria-hidden="true">
    <!-- backdrop close typo fixed -->
    <div class="custom-featured-collection__modal-backdrop" data-close-modal="{{ product.id }}"></div>

    <div class="custom-featured-collection__modal-content">
        <button type="button" class="custom-featured-collection__modal-close" data-close-modal="{{ product.id }}" aria-label="Close Modal">&times;</button>

        <div class="custom-featured-collection__modal-header">
            <div class="custom-featured-collection__modal-img-wrapper">
                {% if product.featured_media != blank %}
                    <img src="{{ product.featured_media | image_url: width: 300 }}" alt="{{ product.title | escape }}" class="custom-featured-collection__modal-img" loading="lazy">
                {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'custom-featured-collection__modal-placeholder' }}
                {% endif %}
            </div>
            <div class="custom-featured-collection__modal-info">
                <h3 class="custom-featured-collection__modal-title">{{ product.title }}</h3>
                <p class="custom-featured-collection__modal-price">{{ product.price | money }}</p>
                {% if product.description != blank %}
                    <p class="custom-featured-collection__modal-desc">
                        {{ product.description | strip_html | truncatewords: 20 }}
                    </p>
                {% endif %}
            </div>
        </div>

        {% form 'product', product, class: 'custom-featured-collection__modal-form' %}
            <!-- 1. Product Variants JSON (ADDED) -->
            <script type="application/json" class="product-variants-json">
              {{ product.variants | json }}
            </script>

            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

            {% unless product.has_only_default_variant %}
                <div class="custom-featured-collection__modal-options">
                    {% for option in product.options_with_values %}
                        <div class="custom-featured-collection__modal-option" data-option-index="{{ forloop.index0 }}">
                            <label class="custom-featured-collection__modal-label">{{ option.name }}</label>

                            {% if forloop.first %}
                                 {% comment %} swatches {% endcomment %}
                                 <div class="custom-featured-collection__swatches">
                                    {% for value in option.values %}
                                        <!-- data-value typo FIXED -->
                                        <button type="button" class="custom-featured-collection__swatch {% if option.selected_value == value %} is-selected {% endif %}"
                                        data-value="{{ value | escape }}">
                                            <span class="custom-featured-collection__swatch-color" style="background-color: {{ value | downcase }}"></span>
                                            <span class="custom-featured-collection__swatch-text">{{ value }}</span>
                                        </button>
                                    {% endfor %}
                                 </div>

                                 <!-- Hidden Select dropdown for swatches (ADDED BACK) -->
                                 <select name="options[{{ option.name }}]" class="custom-featured-collection__hidden-select" style="display: none;">
                                    {% for value in option.values %}
                                        <option value="{{ value | escape }}" {% if option.selected_value == value %}selected="selected"{% endif %}>
                                            {{ value }}
                                        </option>
                                    {% endfor %}
                                 </select>
                            {% else %}
                                 {% comment %} dropdown for other option {% endcomment %}
                                 <div class="custom-featured-collection__select-wrapper">
                                    <select name="options[{{ option.name }}]" class="custom-featured-collection__modal-select">
                                        <option value="" disabled {% if option.selected_value == blank %}selected{% endif %}>Choose your {{ option.name | downcase }}</option>
                                        {% for value in option.values %}
                                            <!-- Selected check FIXED -->
                                            <option value="{{ value | escape }}" {% if option.selected_value == value %}selected="selected"{% endif %}>
                                                {{ value }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                    {{ 'custom-arrow-down.svg' | inline_asset_content }}
                                 </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endunless %}

            <button type="submit" class="custom-featured-collection__modal-submit" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
                <span>
                    {% if product.selected_or_first_available_variant.available %}
                        Add to Cart
                    {% else %}
                        Sold out
                    {% endif %}
                </span>
                {{ 'custom-white-arrow.svg' | inline_asset_content }}
            </button>
        {% endform %}
    </div>
</div>
                    </div>
                {% endfor %}
            {% else %}
                {% comment %} placeolder images {% endcomment %}
                {% for i in (1..limit) %}
                    {%- capture hotspot_pos -%} {% cycle 'pos-1', 'pos-2', 'pos-3', 'pos-4', 'pos-5', 'pos-6', %} {%- endcapture -%}
                    <div class="custom-featured-collection__card custom-featured-collection__card--placeholder" data-product-handle="placeholder">
                        <div class="custom-featured-collection__media">
                            {% assign placeholder_index = i  | modulo: 6 | plus: 1%}
                            {{ 'product-' | append: placeholder_index | placeholder_svg_tag: 'custom-featured-collection__placeholder' }}
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</div>

<script>
    const plusBtn = document.querySelectorAll('.custom-featured-collection__hotspot');
    const closeBtns = document.querySelectorAll('.custom-featured-collection__modal-close');
    const colorSwatch = document.querySelectorAll('.custom-featured-collection__swatch');
    const modal = document.querySelectorAll('.custom-featured-collection__modal');
    
    
    plusBtn.forEach(button => {
        button.addEventListener('click', function(e) {
            const targetId = button.getAttribute('data-target');
            console.log(targetId);
            const targetModal = document.getElementById(targetId);
            console.log(targetModal);
            const closeModal = e.target.closest('[data-close-modal]');

            if (targetModal) {
                targetModal.classList.add('is-active');
                targetModal.setAttribute('aria-hidden', 'false');
                button.setAttribute('aria-expanded', 'true');
                document.body.classList.add('custom-featured-collection-modal-open');
            }
        });
    });

    closeBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            // Find the specific modal this close button/backdrop belongs to
            const targetModal = btn.closest('.custom-featured-collection__modal');
            if (targetModal) {
                targetModal.classList.remove('is-active');
                targetModal.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('custom-featured-collection-modal-open');
                
                // Find the button that opened this modal and reset its accessibility state
                const triggerBtn = document.querySelector(`[data-target="${targetModal.id}"]`);
                if (triggerBtn) {
                    triggerBtn.setAttribute('aria-expanded', 'false');
                }
            }
        });
    });

  document.addEventListener('DOMContentLoaded', function() {
    
    // 1. Color Swatches (Buttons) click listener
    const colorSwatches = document.querySelectorAll('.custom-featured-collection__swatch');
    
    colorSwatches.forEach(swatch => {
        swatch.addEventListener('click', function() {
            const swatchGroup = swatch.closest('.custom-featured-collection__swatches');
            const optionBlock = swatch.closest('.custom-featured-collection__modal-option');
            const modal = swatch.closest('.custom-featured-collection__modal'); // modal ko yahan select kiya

            if (!swatchGroup || !optionBlock || !modal) return;

            // Swatches ki class toggle karein
            swatchGroup.querySelectorAll('.custom-featured-collection__swatch').forEach(btn => {
                btn.classList.remove('is-selected');
            });
            swatch.classList.add('is-selected');

            // Hidden select ki value ko swatch button ke data-value se update karein
            const hiddenSelect = optionBlock.querySelector('.custom-featured-collection__hidden-select');
            if (hiddenSelect) {
                hiddenSelect.value = swatch.getAttribute('data-value');
            }

            // Variant ko update karne wala function call karein
            updateVariant(modal);
        });
    });

    // 2. Normal dropdown selects change listener
    const selects = document.querySelectorAll('.custom-featured-collection__modal-select');
    selects.forEach(select => {
        select.addEventListener('change', function() {
            const modal = select.closest('.custom-featured-collection__modal');
            if (modal) {
                updateVariant(modal);
            }
        });
    });

    // 3. MAIN FUNCTION: Jo variant match karega aur update karega
    function updateVariant(modal) {
        const variantsData = modal.querySelector('.product-variants-json');
        if (!variantsData) return;

        const variants = JSON.parse(variantsData.textContent);

        // Select kiye hue options ko array mein jama karein
        const selectedOptions = [];
        modal.querySelectorAll('.custom-featured-collection__modal-option select').forEach(select => {
            selectedOptions.push(select.value);
        });

        // Variant match karein
        const matchedVariant = variants.find(variant => {
            return variant.options.every((opt, index) => opt === selectedOptions[index]);
        });

        const idInput = modal.querySelector('input[name="id"]');
        const submitBtn = modal.querySelector('.custom-featured-collection__modal-submit');
        const submitBtnText = submitBtn.querySelector('span');

        if (matchedVariant) {
            idInput.value = matchedVariant.id; // Hidden ID update ho gayi

            if (matchedVariant.available) {
                submitBtn.disabled = false;
                submitBtnText.textContent = 'ADD TO CART';
            } else {
                submitBtn.disabled = true;
                submitBtnText.textContent = 'SOLD OUT';
            }
        } else {
            // Agar variant combination market mein available nahi hai
            submitBtn.disabled = true;
            submitBtnText.textContent = 'UNAVAILABLE';
        }
    }

    const forms = document.querySelectorAll('.custom-featured-collection__modal-form');
    forms.forEach(form => {
        form.addEventListener('submit', function(e) {
            e.preventDefault(); // Default reload roka

            // Simple fetch request
            fetch('/cart/add.js', {
                method: 'POST',
                body: new FormData(form)
            })
            .then(response => response.json())
            .then(data => {
                // Cart count ya drawer update karne ke liye event (Zaroori hai)
                document.dispatchEvent(new CustomEvent('cart:updated'));
                setTimeout(() => {
                    // Close modal
                    const modal = form.closest('.custom-featured-collection__modal');
                    if (modal) {
                    modal.classList.remove('is-active');
                    modal.setAttribute('aria-hidden', 'true');
                    document.body.classList.remove('custom-featured-collection-modal-open');
                    }
                }, 1500);
            })
            .catch(error => {
            console.error('Error adding to cart:', error);
            });
        });
    });
});
</script>


{% schema %}
{
    "name": "Custom collection",
    "settings": [
        {
            "type": "product_list",
            "id": "product_list",
            "label": "Products"
        },
        {
            "type": "range",
            "id": "columns_desktop",
            "min": 2,
            "max": 6,
            "step": 1,
            "label": "Columns (desktop)",
            "default": 3
        },
        {
            "type": "range",
            "id": "products_to_show",
            "min": 2,
            "max": 24,
            "step": 1,
            "label": "Total products to show",
            "default": 6
        }
    ],
    "presets": [
        {
            "name": "Custom collection"
        }
    ]
}
{% endschema %}
