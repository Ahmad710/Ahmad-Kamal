{{ 'custom-header.css' | asset_url | stylesheet_tag }}

<header>

</header>


{% schema %}
{
    "name": "Custom header",
    "settings": [
        {
            "type": "header",
            "content": "Logo settings"
        },
        {
            "type": "image_picker",
            "id": "logo_image",
            "label": "Logo"
        },
        {
            "type": "text",
            "id": "logo_text",
            "label": "Logo text",
            "default": "TISSO VISION"
        },
        {
            "type": "range",
            "id": "logo_width_desktop",
            "min": 50,
            "max": 300,
            "step": 10,
            "unit": "px",
            "label": "Logo width (desktop)",
            "default": 150
        },
        {
            "type": "range",
            "id": "logo_width_mobile",
            "min": 50,
            "max": 200,
            "step": 10,
            "unit": "px",
            "label": "Logo width (desktop)",
            "default": 90
        }
    ]
}
{% endschema %}